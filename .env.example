# EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo a .env y completa con tus valores

# ===== SUPABASE =====
# URL pública de tu proyecto (seguro publicar)
VITE_SUPABASE_URL=https://your-project.supabase.co

# ANON KEY (es segura - solo tiene permisos limitados por RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===== PRODUCCIÓN =====
# Solo para build
VITE_ENV=production

# ===== STRIPE (si usas pagos - NUNCA publiques secret key) =====
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx (público OK)
# STRIPE_SECRET_KEY=sk_live_xxx (NUNCA en cliente - va en servidor)

# ===== GOOGLE ANALYTICS =====
# VITE_GA_ID=G-xxxxxx (opcional)

# ===== BASE URL =====
# Para desarrollo
VITE_API_URL=http://localhost:5173

# Para producción (cambiar según tu dominio)
# VITE_API_URL=https://app.tudominio.com
